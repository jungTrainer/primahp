rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function adminDoc(){ return get(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function publisherDoc(){ return get(/databases/$(database)/documents/mealPublishers/$(request.auth.uid)); }
    function isAdmin(){ return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && adminDoc().data.active == true; }
    function isSuperAdmin(){ return isAdmin() && (!adminDoc().data.keys().hasAny(['role']) || adminDoc().data.role == 'super-admin'); }
    function isMealPublisher(){ return signedIn() && exists(/databases/$(database)/documents/mealPublishers/$(request.auth.uid)) && publisherDoc().data.active == true; }
    function validConsent(v){ return request.resource.data.privacyConsent == true && request.resource.data.consentedAt is string && request.resource.data.privacyPolicyVersion == v; }

    match /admins/{uid}{
      allow read: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }
    match /mealPublishers/{uid}{
      allow read: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }
    match /accessRequests/{uid}{
      allow create: if signedIn() && request.auth.uid == uid && request.resource.data.status == 'pending';
      allow read: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }
    match /artifacts/{appId}/public/data/inquiries/{id}{
      allow create: if signedIn() && validConsent('2026-07-15') && request.resource.data.sensitiveConsent == true;
      allow read, update, delete: if isAdmin();
    }
    match /artifacts/{appId}/public/data/comments/{id}{
      allow create: if signedIn() && validConsent('2026-07-15');
      allow read, update, delete: if isAdmin();
    }
    match /artifacts/{appId}/public/data/meals/{id}{
      allow read: if true;
      allow create, update, delete: if isAdmin() || isMealPublisher();
    }
    match /artifacts/{appId}/public/data/{collectionName}/{id}{
      allow read: if collectionName in ['notices','staff','gallery','facilities','certifications','page-content','departments'];
      allow create, update, delete: if isAdmin();
    }
    match /{document=**}{ allow read, write: if false; }
  }
}
